  "plano_ia": {
    "biblioteca_recomendada": "playwright",
    "usar_api_direta": false,
    "url_api": "",
    "justificativa": "N\u00e3o h\u00e1 API p\u00fablica dispon\u00edvel. O site possui modais de tutorial que precisam ser fechados, m\u00faltiplas p\u00e1ginas de conjuntos de dados que precisam ser navegadas, e cada conjunto possui seus pr\u00f3prios arquivos CSV. \u00c9 necess\u00e1rio intera\u00e7\u00e3o din\u00e2mica com JavaScript para fechar modais, navegar entre p\u00e1ginas e acessar os detalhes de cada dataset.",
    "fluxo_navegacao": [
      "Passo 1: Acessar https://dadosabertos.curitiba.pr.gov.br/",
      "Passo 2: Fechar modal de boas-vindas clicando no 'X' ou 'Pular tutorial'",
      "Passo 3: Navegar para se\u00e7\u00e3o 'Conjuntos de Dados' no menu superior",
      "Passo 4: Extrair total de resultados e calcular n\u00famero de p\u00e1ginas",
      "Passo 5: Para cada p\u00e1gina de resultados, coletar todos os links dos cards de datasets (href contendo '/conjuntodado/detalhe?chave=')",
      "Passo 6: Para cada dataset, acessar p\u00e1gina de detalhe",
      "Passo 7: Fechar modal de tutorial se aparecer novamente",
      "Passo 8: Identificar e baixar todos os arquivos CSV dispon\u00edveis no dataset",
      "Passo 9: Voltar e repetir para pr\u00f3xima p\u00e1gina de resultados at\u00e9 finalizar todas as p\u00e1ginas",
      "Passo 10: Registrar downloads realizados e falhas"
    ],
    "seletores_chave": {
      "fechar_modal_tutorial": "button.close, .modal button[aria-label='Close'], button:has-text('Pular tutorial')",
