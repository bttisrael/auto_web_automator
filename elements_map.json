      "lista_itens": "a[href*='conjuntodado/detalhe?chave=']",
      "botao_download": "a[href$='.csv'], a[download][href*='.csv'], button:has-text('Baixar'), a:has-text('CSV')",
      "proxima_pagina": ".pagination a:has-text('Pr\u00f3xima'), .pagination a[rel='next'], button:has-text('Pr\u00f3xima')",
      "campo_busca": "input[type='search'], input[placeholder*='Buscar']",
