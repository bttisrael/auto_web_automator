  "ia_analise": {
    "biblioteca_recomendada": "playwright",
    "justificativa": "Playwright \u00e9 superior para este caso pois o site utiliza jQuery e Bootstrap com conte\u00fado din\u00e2mico. Possui melhor suporte para esperar elementos carregados via JS, intercepta\u00e7\u00e3o de requisi\u00e7\u00f5es de rede para capturar URLs dos CSVs, e \u00e9 mais est\u00e1vel para download de m\u00faltiplos arquivos",
    "estrategia": "1) Acessar a p\u00e1gina principal e aguardar carregamento completo; 2) Identificar todos os conjuntos de dados atrav\u00e9s de links ou cards na p\u00e1gina; 3) Para cada conjunto, acessar a p\u00e1gina de detalhes; 4) Localizar e extrair URLs dos arquivos CSV (podem estar em bot\u00f5es de download ou links diretos); 5) Implementar loop para navegar por todas as p\u00e1ginas de datasets se houver pagina\u00e7\u00e3o; 6) Realizar download program\u00e1tico dos CSVs ou coletar URLs e baixar via requests; 7) Organizar arquivos baixados com nomenclatura apropriada",
    "elementos_chave": [
      "form.busca[action='/conjuntodado/']",
      "input[name='termo']",
      "a[href*='csv'], button[download], a[download]",
      "links para p\u00e1ginas de datasets individuais",
      "elementos de pagina\u00e7\u00e3o (se existirem)",
      "bot\u00f5es ou links com texto 'Download', 'CSV', 'Baixar'"
    ],
    "alertas": [
      "Pagina\u00e7\u00e3o din\u00e2mica pode exigir cliques ou scroll infinito",
      "CSVs podem estar dentro de p\u00e1ginas de detalhes individuais, n\u00e3o na listagem principal",
      "Poss\u00edvel limite de rate limiting para m\u00faltiplos downloads",
      "Arquivos podem ter nomes gen\u00e9ricos, necessitando renomea\u00e7\u00e3o baseada em metadados",
      "Token CSRF presente (__RequestVerificationToken) pode ser necess\u00e1rio para algumas intera\u00e7\u00f5es"
    ],
    "complexidade": "media"
  }
}